#!/bin/sh

# commitlint 실행
npx commitlint --edit "$1"
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo ""
  echo "❌ Commit message 규칙:"
  echo "- feat: 기능 추가"
  echo "- fix: 버그 수정"
  echo "- chore: 기타 작업 (빌드, 설정 등)"
  echo "- refactor: 리팩토링"
  echo "- docs: 문서 수정"
  echo "- test: 테스트 코드"
  echo "- style: 코드 스타일 (formatting)"
  echo ""
fi

exit $RESULT